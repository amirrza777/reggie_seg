{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev": "NEXT_DEV_DIST_DIR=.next-dev-turbo next dev --turbopack -p 3001",
    "dev:clean": "rimraf .next .next-dev-turbo .next-dev-webpack && NEXT_DEV_DIST_DIR=.next-dev-turbo next dev --turbopack -p 3001",
    "dev:webpack": "NEXT_DEV_DIST_DIR=.next-dev-webpack next dev -p 3001",
    "build": "next build",
    "prestart": "node scripts/ensure-next-build.js",
    "start": "next start -p 3001",
    "lint": "next lint && npm run lint:responsive",
    "lint:responsive": "node scripts/check-responsive-contract.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "node scripts/run-vitest-coverage.mjs",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:responsive": "playwright test e2e/responsive/public-routes.spec.ts",
    "test:e2e:responsive:auth": "PLAYWRIGHT_AUTH_TESTS=1 PLAYWRIGHT_REQUIRE_API=1 playwright test e2e/responsive/authenticated-routes.spec.ts --workers=1 --retries=1",
    "test:responsive:sitewide": "npm run lint:responsive && npm run test:e2e:responsive",
    "test:responsive:sitewide:full": "npm run lint:responsive && npm run test:e2e:responsive && npm run test:e2e:responsive:auth",
    "postinstall": "npm rebuild esbuild",
    "lint:functions": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0 --ignore-pattern \"**/*.test.*\" --ignore-pattern \"**/*.spec.*\" --ignore-pattern \"**/__tests__/**\" --ignore-pattern \"**/*.test-helpers.*\""
  },
  "dependencies": {
    "@lexical/react": "^0.40.0",
    "lexical": "^0.40.0",
    "lucide-react": "^0.575.0",
    "next": "^15.5.15",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.2",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.5.9",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "jsdom": "^26.0.0",
    "rimraf": "^6.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^2.1.2"
  },
  "overrides": {
    "@jridgewell/sourcemap-codec": "1.4.15"
  }
}
