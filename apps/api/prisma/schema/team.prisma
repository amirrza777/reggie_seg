enum InactivityFlag {
  NONE
  YELLOW
  RED
}

enum DeadlineProfile {
  STANDARD
  MCF
}

enum TeamAllocationLifecycle {
  DRAFT
  ACTIVE
}

model Team {
  id                         Int             @id @default(autoincrement())
  enterpriseId               String
  projectId                  Int
  teamName                   String
  allocationLifecycle        TeamAllocationLifecycle @default(ACTIVE)
  draftCreatedById           Int?
  draftApprovedById          Int?
  draftApprovedAt            DateTime?
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt
  archivedAt                 DateTime?
  inactivityFlag             InactivityFlag  @default(NONE)
  deadlineProfile            DeadlineProfile @default(STANDARD)
  noGithubAccountAlertSentAt  DateTime?
  peerAssessmentAlertSentAt   DateTime?

  allocations          TeamAllocation[]
  project              Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  enterprise           Enterprise            @relation(fields: [enterpriseId], references: [id], onDelete: Restrict)
  draftCreatedBy       User?                 @relation("TeamDraftCreatedBy", fields: [draftCreatedById], references: [id], onDelete: SetNull)
  draftApprovedBy      User?                 @relation("TeamDraftApprovedBy", fields: [draftApprovedById], references: [id], onDelete: SetNull)
  deadlineOverride     TeamDeadlineOverride? @relation("TeamDeadlineOverride")
  peerAssessments      PeerAssessment[]
  peerFeedbacks        PeerFeedback[]
  teamHealthMessages   TeamHealthMessage[]
  teamWarnings         TeamWarning[]
  staffTeamMarking     StaffTeamMarking?
  staffStudentMarkings StaffStudentMarking[]
  meetings             Meeting[]

  trelloBoardId       String?
  trelloOwnerId       Int?
  trelloOwner         User?        @relation("TrelloOwner", fields: [trelloOwnerId], references: [id])
  trelloSectionConfig Json?
  invites             TeamInvite[]

  @@unique([projectId, teamName])
  @@unique([enterpriseId, teamName])
  @@index([projectId])
  @@index([enterpriseId])
  @@index([allocationLifecycle])
  @@index([draftCreatedById])
  @@index([draftApprovedById])
}
