enum InactivityFlag {
  NONE
  YELLOW
  RED
}

model Team {
  id              Int              @id @default(autoincrement())
  enterpriseId    String
  projectId       Int
  teamName        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  archivedAt                 DateTime?
  inactivityFlag             InactivityFlag   @default(NONE)
  noGithubAccountAlertSentAt DateTime?

  allocations     TeamAllocation[]
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  enterprise      Enterprise       @relation(fields: [enterpriseId], references: [id], onDelete: Restrict)
  deadlineOverride TeamDeadlineOverride? @relation("TeamDeadlineOverride")
  peerAssessments PeerAssessment[]
  peerFeedbacks   PeerFeedback[]
  staffTeamMarking StaffTeamMarking?
  staffStudentMarkings StaffStudentMarking[]
  meetings        Meeting[]
  
  trelloBoardId      String?
  trelloOwnerId      Int?
  trelloOwner        User?   @relation("TrelloOwner", fields: [trelloOwnerId], references: [id])
  trelloSectionConfig Json? 
  invites            TeamInvite[]

  @@unique([projectId, teamName])
  @@index([projectId])
  @@index([enterpriseId])
  @@unique([enterpriseId, teamName])
}
