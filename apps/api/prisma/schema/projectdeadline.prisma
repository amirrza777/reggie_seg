model ProjectDeadline {
  id                   Int       @id @default(autoincrement())
  projectId            Int       @unique
  taskOpenDate         DateTime
  taskDueDate          DateTime
  taskDueDateMcf       DateTime?
  assessmentOpenDate   DateTime
  assessmentDueDate    DateTime
  assessmentDueDateMcf DateTime?
  feedbackOpenDate     DateTime
  feedbackDueDate      DateTime
  feedbackDueDateMcf   DateTime?
  teamAllocationQuestionnaireOpenDate DateTime?
  teamAllocationQuestionnaireDueDate  DateTime?
  teamAllocationInviteDueDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project          Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  teamOverrides    TeamDeadlineOverride[]
  studentOverrides StudentDeadlineOverride[]

  @@index([projectId])
}
