model StaffTeamMarking {
  id                Int      @id @default(autoincrement())
  teamId            Int      @unique
  markerUserId      Int
  mark              Float?
  formativeFeedback String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  marker User @relation("StaffTeamMarker", fields: [markerUserId], references: [id])

  @@index([markerUserId])
}

model StaffStudentMarking {
  id                Int      @id @default(autoincrement())
  teamId            Int
  studentUserId     Int
  markerUserId      Int
  mark              Float?
  formativeFeedback String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  team    Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  student User @relation("StaffStudentMarkingStudent", fields: [studentUserId], references: [id])
  marker  User @relation("StaffStudentMarker", fields: [markerUserId], references: [id])

  @@unique([teamId, studentUserId])
  @@index([teamId])
  @@index([studentUserId])
  @@index([markerUserId])
}
