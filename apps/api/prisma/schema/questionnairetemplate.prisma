enum QuestionnairePurpose {
  PEER_ASSESSMENT
  CUSTOMISED_ALLOCATION
  GENERAL_PURPOSE
}

model QuestionnaireTemplate {
  id           Int              @id @default(autoincrement())
  templateName String
  purpose      QuestionnairePurpose @default(GENERAL_PURPOSE)
  isPublic     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  assessments  PeerAssessment[] @relation("TemplateAssessments")
  questions    Question[]
  projects     Project[]        @relation("ProjectTemplate")
  teamAllocationProjects Project[] @relation("ProjectTeamAllocationTemplate")

  ownerId Int
  owner   User @relation(fields: [ownerId], references: [id])

  @@index([id])
}
