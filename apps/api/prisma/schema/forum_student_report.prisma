enum ForumStudentReportStatus {
  PENDING
  APPROVED
  IGNORED
}

model ForumStudentReport {
  id          Int                     @id @default(autoincrement())
  projectId   Int
  postId      Int
  reporterId  Int
  status      ForumStudentReportStatus @default(PENDING)
  reason      String?
  createdAt   DateTime                @default(now())
  reviewedAt  DateTime?
  reviewedById Int?

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  post       DiscussionPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter   User    @relation("ForumStudentReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedBy User?   @relation("ForumStudentReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([postId, status])
  @@index([reporterId, createdAt])
  @@index([reviewedById])
  @@unique([postId, reporterId])
}
