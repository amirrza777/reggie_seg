model ForumReport {
  id         Int      @id @default(autoincrement())
  projectId  Int
  postId     Int
  reporterId Int
  authorId   Int
  parentPostId Int?
  reason     String?
  title      String
  body       String
  postCreatedAt DateTime
  postUpdatedAt DateTime
  createdAt  DateTime @default(now())

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reporter User    @relation("ForumReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  author   User    @relation("ForumReportAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([projectId, createdAt])
  @@index([reporterId, createdAt])
  @@index([parentPostId])
}
