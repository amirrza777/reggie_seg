enum Role {
  STUDENT
  STAFF
  ENTERPRISE_ADMIN
  ADMIN
}

model User {
  id                       Int                       @id @default(autoincrement())
  enterpriseId             String
  email                    String
  createdAt                DateTime                  @default(now())
  avatarData               Bytes?
  avatarMime               String?
  firstName                String
  role                     Role                      @default(STUDENT)
  lastName                 String
  passwordHash             String
  active                   Boolean                   @default(true)
  updatedAt                DateTime                  @updatedAt
  enterprise               Enterprise                @relation(fields: [enterpriseId], references: [id], onDelete: Restrict)
  moduleLeads              ModuleLead[]
  moduleTeachingAssistants ModuleTeachingAssistant[]
  revieweeAssessments      PeerAssessment[]          @relation("PeerAssessmentReviewee")
  reviewerAssessments      PeerAssessment[]          @relation("PeerAssessmentReviewer")
  teamAllocations          TeamAllocation[]
  userModules              UserModule[]
  meetingOrganisers        Meeting[]                 @relation("MeetingOrganiser")
  meetingAttendances       MeetingAttendance[]       @relation("MeetingAttendance")
  meetingMinutes           MeetingMinutes[]          @relation("MeetingMinutesWriter")
  meetingComments          MeetingComment[]          @relation("MeetingComment")
  refreshTokens            RefreshToken[]
  passwordResetTokens      PasswordResetToken[]
  emailChangeTokens        EmailChangeToken[]

  trelloToken           String?
  trelloMemberId        String?
  ownedTeamTrelloBoards Team[]  @relation("TrelloOwner")
  draftTeamsCreated     Team[]  @relation("TeamDraftCreatedBy")
  draftTeamsApproved    Team[]  @relation("TeamDraftApprovedBy")

  questionnaires                  QuestionnaireTemplate[]
  reviewerFeedbacks               PeerFeedback[]               @relation("PeerFeedbackReviewer")
  revieweeFeedbacks               PeerFeedback[]               @relation("PeerFeedbackReviewee")
  staffTeamMarkingsGiven          StaffTeamMarking[]           @relation("StaffTeamMarker")
  staffStudentMarkingsGiven       StaffStudentMarking[]        @relation("StaffStudentMarker")
  staffStudentMarkingsReceived    StaffStudentMarking[]        @relation("StaffStudentMarkingStudent")
  githubAccount                   GithubAccount?
  linkedGithubRepos               ProjectGithubRepository[]    @relation("ProjectGithubRepositoryLinkedBy")
  analysedGithubSnapshots         GithubRepoSnapshot[]         @relation("GithubRepoSnapshotAnalysedBy")
  mappedGithubStats               GithubRepoSnapshotUserStat[] @relation("GithubRepoSnapshotUserStatMappedUser")
  teamInvitesSent                 TeamInvite[]                 @relation("TeamInvitesSent")
  teamInvitesReceived             TeamInvite[]                 @relation("TeamInvitesReceived")
  teamHealthMessagesCreated       TeamHealthMessage[]          @relation("TeamHealthMessageRequester")
  teamHealthMessagesReviewed      TeamHealthMessage[]          @relation("TeamHealthMessageReviewer")
  studentDeadlineOverrides        StudentDeadlineOverride[]    @relation("StudentDeadlineOverrideStudent")
  createdStudentDeadlineOverrides StudentDeadlineOverride[]    @relation("StudentDeadlineOverrideCreatedBy")
  auditLogs                       AuditLog[]
  mentions                        Mention[]                    @relation("Mention")
  notifications                   Notification[]               @relation("Notification")

  @@unique([id, enterpriseId])
  @@unique([enterpriseId, email])
  @@index([enterpriseId])
}
