model Project {
  id                    Int                   @id @default(autoincrement())
  moduleId              Int
  name                  String
  questionnaireTemplateId Int
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  archivedAt            DateTime?

  module                Module                @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questionnaireTemplate QuestionnaireTemplate @relation("ProjectTemplate", fields: [questionnaireTemplateId], references: [id])
  teams                 Team[]
  peerAssessments       PeerAssessment[]
  deadline              ProjectDeadline?
  githubRepositories    ProjectGithubRepository[]
  forumIsAnonymous Boolean @default(false)
  discussionPosts       DiscussionPost[]
  forumReports         ForumReport[]

  @@index([moduleId])
  @@index([questionnaireTemplateId])
}
