{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "predev": "prisma generate && prisma migrate deploy",
    "prestart": "prisma generate && prisma migrate deploy",
    "start": "tsx src/index.ts",
    "test": "vitest run --silent",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --silent",
    "test:modulejoin": "vitest run --config vitest.modulejoin.config.ts --silent",
    "test:modulejoin:coverage": "vitest run --config vitest.modulejoin.config.ts --coverage --silent",
    "loadtest:modulejoin": "node scripts/loadtest-module-join.js",
    "quality:modulejoin-seed": "node scripts/quality-modulejoin-seed.js",
    "check:modulejoin-seed": "npm run test:modulejoin && npm run test:seed && npm run quality:modulejoin-seed",
    "test:seed": "vitest run --config vitest.seed.config.ts --silent",
    "test:seed:coverage": "vitest run --config vitest.seed.config.ts --coverage --silent",
    "dev": "tsx --watch src/index.ts",
    "db:seed": "prisma generate && tsx prisma/seed/seed.ts",
    "db:unseed": "tsx prisma/seed/unseed.ts",
    "lint": "node scripts/verify-dev-deps.js && npx eslint \"src/**/*.{ts,tsx}\"",
    "lint:functions": "node scripts/verify-dev-deps.js && npx eslint \"src/**/*.{ts,tsx}\" --max-warnings 0 --ignore-pattern \"**/*.test.*\" --ignore-pattern \"**/*.spec.*\" --ignore-pattern \"**/__tests__/**\" --ignore-pattern \"**/*.test-helpers.*\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "overrides": {
    "@jridgewell/sourcemap-codec": "1.4.15",
    "fast-check": "3.23.1"
  },
  "type": "module",
  "dependencies": {
    "@ngneat/falso": "^8.0.2",
    "@prisma/client": "^6.19.2",
    "argon2": "^0.44.0",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.9",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^2.1.2",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "supertest": "^7.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.1.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed/seed.ts"
  }
}
